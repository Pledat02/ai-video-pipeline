# Copy file này thành .env rồi điền giá trị thật. KHÔNG commit .env.

# Provider sinh kịch bản: stub | claude | gemini
SCRIPT_GENERATION_PROVIDER=gemini

# Claude API (nếu dùng provider=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Gemini API (nếu dùng provider=gemini) - lấy key free tại https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Agent tạo ảnh qua MCP Streamable HTTP. Mặc định chỉ cho localhost.
MCP_IMAGE_SERVER_URL=http://127.0.0.1:8189/mcp
MCP_IMAGE_TOOL=generate_image
MCP_IMAGE_AUTH_TOKEN=
MCP_IMAGE_TIMEOUT_SECONDS=180
MCP_IMAGE_ALLOW_REMOTE=false

# Text-to-speech: stub | edge-tts (cần: pip install edge-tts)
TTS_PROVIDER=edge-tts
TTS_EXECUTABLE=edge-tts
TTS_VOICE=vi-VN-HoaiMyNeural

# Render video: stub | ffmpeg (cần cài FFmpeg, có sẵn trong PATH)
VIDEO_RENDER_PROVIDER=ffmpeg
FFMPEG_EXECUTABLE=ffmpeg
FFPROBE_EXECUTABLE=ffprobe
FFMPEG_RESOLUTION=1280x720
FFMPEG_BACKGROUND_COLOR=0x1a1a2e
FFMPEG_FONT_SIZE=28

# Database: bỏ trống để dùng H2 in-memory, hoặc trỏ tới Postgres/Supabase
DB_URL=
DB_USERNAME=
DB_PASSWORD=
